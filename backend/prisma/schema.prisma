// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Creator {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  walletAddress String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ipAssets IPAsset[]

  @@map("creators")
}

model IPAsset {
  id             String   @id @default(cuid())
  title          String
  description    String?
  creatorId      String
  tokenId        String   @unique
  contractAddress String
  type           IPType
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator      Creator       @relation(fields: [creatorId], references: [id])
  stakeholders Stakeholder[]
  usageRecords UsageRecord[]
  payments     RoyaltyPayment[]

  @@map("ip_assets")
}

model Stakeholder {
  id                String   @id @default(cuid())
  name              String
  email             String
  walletAddress     String
  role              StakeholderRole
  royaltyPercentage Float
  ipAssetId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ipAsset  IPAsset          @relation(fields: [ipAssetId], references: [id])
  payments RoyaltyPayment[]

  @@map("stakeholders")
}

model UsageRecord {
  id         String     @id @default(cuid())
  ipAssetId  String
  platform   String
  usageType  UsageType
  amount     Float
  currency   String
  timestamp  DateTime   @default(now())
  metadata   Json?
  createdAt  DateTime   @default(now())

  ipAsset        IPAsset          @relation(fields: [ipAssetId], references: [id])
  royaltyPayments RoyaltyPayment[]

  @@map("usage_records")
}

model RoyaltyPayment {
  id              String           @id @default(cuid())
  stakeholderId   String
  ipAssetId       String
  usageRecordId   String?
  amount          Float
  currency        String
  transactionHash String?          @unique
  status          PaymentStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  processedAt     DateTime?
  metadata        Json?

  stakeholder Stakeholder  @relation(fields: [stakeholderId], references: [id])
  ipAsset     IPAsset      @relation(fields: [ipAssetId], references: [id])
  usageRecord UsageRecord? @relation(fields: [usageRecordId], references: [id])

  @@map("royalty_payments")
}

model PlatformIntegration {
  id          String   @id @default(cuid())
  name        String   @unique
  apiKey      String   @unique
  webhookUrl  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("platform_integrations")
}

enum IPType {
  MUSIC
  VIDEO
  ART
  TEXT
  SOFTWARE
}

enum StakeholderRole {
  CREATOR
  PRODUCER
  DISTRIBUTOR
  PUBLISHER
  OTHER
}

enum UsageType {
  STREAM
  DOWNLOAD
  LICENSE
  SALE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}
